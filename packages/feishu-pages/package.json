{
  "name": "@pange/feishu-pages",
  "version": "0.1.1",
  "description": "将飞书Wiki生成为Markdown，用于配合静态页面生成器使用",
  "keywords": [
    "feishu",
    "lark",
    "wiki",
    "markdown"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yangzupan/feishu-pages"
  },
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Pange Team"
  },
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "pnpm build && node dist/index.js",
    "release": "pnpm build && npm publish --access public"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.63.1",
    "@pange/feishu-docx": "workspace:*",
    "axios": "^1.16.0",
    "dotenv": "^17.4.2",
    "js-yaml": "catalog:",
    "marked": "catalog:",
    "marked-xhtml": "catalog:",
    "mime-types": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
