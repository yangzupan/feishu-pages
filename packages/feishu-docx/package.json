{
  "name": "@pange/feishu-docx",
  "version": "0.1.4",
  "description": "将飞书文档转换为其他格式（Markdown、HTML等）",
  "keywords": [
    "feishu",
    "lark",
    "docx",
    "markdown"
  ],
  "module": "src/index.ts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yangzupan/feishu-pages"
  },
  "author": {
    "name": "Pange Team"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "release": "pnpm build && npm publish --access public"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "jsdom": "^29.1.1",
    "marked": "^18.0.3",
    "marked-xhtml": "^1.0.15"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
